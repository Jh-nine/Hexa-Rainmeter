[Variables]
; =============================================
; Hexa Rainmeter Skin - Global Variables
; =============================================

; --- 육각형 기본 크기 ---
HexWidth=100
HexHeight=100

; --- 허니콤 배치 오프셋 (1px 간격 포함) ---
; 면 대 면 너비: 93.5 - 6.5 = 87px
;
; 수평(좌/우) 배치 간격: 87 + 1px = 88
HexOffsetX=88
; 대각선 배치 X 간격: 수평의 절반
HexOffsetDX=44
; 대각선 배치 Y 간격: 높이 3/4 + ~1px
HexOffsetDY=76

; --- 색상 ---
ColorPrimary=200,200,200,255
ColorSecondary=100,180,255,255
ColorAccent=0,200,150,255
ColorBackground=30,30,30,200
ColorBorder=200,200,200,180
ColorText=240,240,240,255
ColorSubText=180,180,180,255
ColorWarning=255,180,50,255
ColorDanger=255,80,80,255

; --- 경고/위험 임계값 (%) ---
WarningThreshold=50
DangerThreshold=80

; --- 선 굵기 ---
BorderWidth=2
InnerBorderWidth=1
InnerLineGap=5

; --- 폰트 ---
FontFace=Smooch Sans SemiBold
FontSize=15
FontSizeSmall=13
FontSizeLarge=19

; --- 아이콘 독 설정 ---
DockColumns=3
DockRows=2

; --- 디스크 ---
DiskDrive=C:

; --- 허니콤 스냅 원점 (스크린 좌표) ---
SnapOriginX=0
SnapOriginY=0

; --- 비주얼라이저 ---
VisualizerLayers=5
VisualizerColor=200,200,200
; 미디어 정보 패널 위치 (1=오른쪽, 0=왼쪽)
MediaInfoSide=1

; --- 업데이트 주기 (ms) ---
UpdateRate=1000