; =============================================
; Hexa - App Dock Configuration
; 이 파일에 앱을 추가하면 자동으로 허니콤 배치됩니다
; =============================================
; 양식:
; AppName_N=앱 이름
; AppPath_N=실행 경로
; AppIcon_N=아이콘 경로 (빈값이면 기본 아이콘)
;
; N은 1부터 순서대로 증가
; AppCount를 앱 수에 맞게 수정

[Variables]
AppCount=3

AppName_1=Google
AppUrl_1=https://www.google.com
AppIcon_1=#@#Icons\google.png

AppName_2=YouTube
AppUrl_2=https://www.youtube.com
AppIcon_2=#@#Icons\youtube.png

AppName_3=YouTube Music
AppUrl_3=https://music.youtube.com
AppIcon_3=#@#Icons\YT-music.png
